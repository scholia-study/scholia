{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "ct": {
            "dependsOn": []
        },
        "lint": {
            "dependsOn": []
        },
        "check:modules": {
            "dependsOn": []
        },
        "test": {
            "dependsOn": []
        },
        "openapi": {
            "outputs": ["../../openapi.json"]
        },
        "codegen": {
            "dependsOn": ["@apps/api#openapi"],
            "outputs": ["src/api/**"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        }
    }
}
