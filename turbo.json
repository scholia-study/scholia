{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "//#openapi": {
      "outputs": ["openapi.json"]
    },
    "codegen": {
      "dependsOn": ["//#openapi"],
      "outputs": ["src/api/**"]
    },
    "//#dev:api": {
      "persistent": true,
      "cache": false
    },
    "dev": {
      "dependsOn": ["//#dev:api"],
      "persistent": true,
      "cache": false
    }
  }
}
