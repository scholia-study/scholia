{
    "name": "@apps/web",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000 --host",
        "ct": "tsc -p tsconfig.json --pretty --noEmit",
        "build": "vite build && cp instrument.server.mjs ./dist/server/",
        "start": "NODE_OPTIONS='--import ./dist/server/instrument.server.mjs' srvx serve --prod --entry ./dist/server/server.js --static ../client --port ${PORT:-3000}",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "check:modules": "node scripts/check-module-imports.mjs",
        "generate-api": "orval",
        "codegen": "orval && pnpx @biomejs/biome check --write ./src/api"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/libre-baskerville": "^5.2.10",
        "@fontsource/roboto": "^5.2.10",
        "@mdxeditor/editor": "^3.53.1",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.3.9",
        "@sentry/cli": "^3.6.0",
        "@sentry/tanstackstart-react": "^10.66.0",
        "@stripe/react-stripe-js": "^6.3.0",
        "@stripe/stripe-js": "^9.4.0",
        "@tanstack/react-query": "^5.101.4",
        "@tanstack/react-router": "^1.170.18",
        "@tanstack/react-router-ssr-query": "^1.167.1",
        "@tanstack/react-start": "^1.168.32",
        "axios": "^1.18.1",
        "driver.js": "^1.8.0",
        "html-react-parser": "^5.2.17",
        "lucide-react": "^1.26.0",
        "marked": "^18.0.5",
        "prismjs": "1.30.0",
        "react": "^19.2.8",
        "react-dom": "^19.2.8",
        "react-hot-toast": "^2.6.0",
        "srvx": "^0.12.4",
        "tailwindcss": "^4.1.18"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.1",
        "@tanstack/devtools-vite": "^0.8.3",
        "@tanstack/react-devtools": "^0.10.9",
        "@tanstack/react-router-devtools": "^1.167.0",
        "@tanstack/router-plugin": "^1.168.23",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^22.10.2",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.2",
        "jsdom": "^29.1.1",
        "nitro": "npm:nitro-nightly@latest",
        "orval": "^8.17.0",
        "typescript": "^5.7.2",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    }
}
