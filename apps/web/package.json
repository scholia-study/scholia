{
    "name": "@apps/web",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "vite dev --port 3000 --host",
        "ct": "tsc -p tsconfig.json --pretty --noEmit",
        "build": "vite build",
        "start": "srvx serve --prod --entry ./dist/server/server.js --static ../client --port ${PORT:-3000}",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "check:modules": "node scripts/check-module-imports.mjs",
        "generate-api": "orval",
        "codegen": "orval && pnpx @biomejs/biome check --write ./src/api"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/libre-baskerville": "^5.2.10",
        "@fontsource/roboto": "^5.2.10",
        "@mdxeditor/editor": "^3.53.1",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.3.9",
        "@stripe/react-stripe-js": "^6.3.0",
        "@stripe/stripe-js": "^9.4.0",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "^1.168.22",
        "@tanstack/react-router-ssr-query": "^1.166.11 ",
        "@tanstack/react-start": "^1.167.41",
        "axios": "^1",
        "driver.js": "^1.4.0",
        "html-react-parser": "^5.2.17",
        "lucide-react": "^1.8.0",
        "marked": "^18.0.0",
        "prismjs": "1.30.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-hot-toast": "^2.6.0",
        "srvx": "^0.11.15",
        "tailwindcss": "^4.1.18"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/devtools-vite": "^0.6.0",
        "@tanstack/react-devtools": "^0.10.2 ",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/router-plugin": "^1.132.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^22.10.2",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^29.0.2",
        "nitro": "npm:nitro-nightly@latest",
        "orval": "^8.8.0",
        "typescript": "^5.7.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}
