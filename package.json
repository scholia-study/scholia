{
  "name": "prospero",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "ready": "pnpm run db:reset && pnpm run extract && pnpm run db:import",
    "db:reset": "./db_reset.sh",
    "extract": "cargo run -p hegel-wdl",
    "db:import": "cargo run -p db-import -- assets/wdl.json",
    "dev": "turbo run dev",
    "codegen": "turbo run codegen"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
