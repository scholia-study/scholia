{
    "name": "scholia",
    "private": true,
    "packageManager": "pnpm@10.31.0",
    "scripts": {
        "h": "jq '.scripts' package.json",
        "validate": "pnpm exec turbo lint ct test check:modules",
        "s": "pnpm run sanity",
        "sanity": "pnpm exec biome format --write && turbo lint ct test check:modules",
        "check": "pnpm exec biome check --write .",
        "prepare": "lefthook install",
        "db:reset": "bash scripts/db_reset.sh",
        "db:kant1": "bash scripts/db_kant1.sh",
        "db:bible": "bash scripts/db_bible.sh",
        "db:reload": "pnpm db:reset && pnpm db:kant1 && pnpm db:bible",
        "db:prepare": "bash scripts/db_prepare.sh",
        "db:dev:forward": "KUBECONFIG=~/.kube/scholia-dev.yaml kubectl port-forward -n scholia svc/postgres 55432:5432",
        "db:dev:run": "bash scripts/db_dev_run.sh",
        "db:dev:reset": "bash scripts/db_dev_reset.sh",
        "db:dev:reload": "bash scripts/db_dev_reset.sh && pnpm db:dev:run pnpm db:kant1 && pnpm db:dev:run pnpm db:bible",
        "assets:sync": "bash scripts/assets_sync.sh",
        "dev": "turbo run dev --filter=@apps/api --filter=@apps/web",
        "dev:all": "APP_PROFILE=local-proxy turbo run dev",
        "dev:proxy": "turbo run dev --filter=@apps/proxy",
        "codegen": "turbo run codegen",
        "dp:kant1": "cargo run -p kant1_ocr_to_lines && cargo run -p kant1_lines_to_elements",
        "dp:kant1:struct": "cargo run -p kant1_md_to_struct && cargo run -p kant1_md_translation_to_struct",
        "stripe:listen": "stripe listen --forward-to localhost:4000/api/webhooks/stripe"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "lefthook": "^2.1.6",
        "turbo": "2.9.6"
    }
}
