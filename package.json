{
    "name": "scholia",
    "private": true,
    "packageManager": "pnpm@10.31.0",
    "scripts": {
        "h": "jq '.scripts' package.json",
        "validate": "pnpm exec turbo lint ct test check:modules",
        "s": "pnpm run sanity",
        "sanity": "pnpm exec biome format --write && turbo lint ct test check:modules",
        "check": "pnpm exec biome check --write .",
        "prepare": "lefthook install",
        "api:sqlx:prep": "bash scripts/db_prepare.sh && pnpm exec biome format --write",
        "db:migrate": "bash scripts/db_migrate.sh",
        "db:schema": "bash scripts/db_schema_dump.sh",
        "dev": "turbo run dev --filter=@apps/api --filter=@apps/web",
        "dev:all": "APP_PROFILE=local-proxy turbo run dev",
        "dev:proxy": "turbo run dev --filter=@apps/proxy",
        "codegen": "turbo run codegen",
        "stripe:listen": "stripe listen --forward-to localhost:4000/api/webhooks/stripe"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "lefthook": "^2.1.9",
        "turbo": "2.9.18"
    }
}
