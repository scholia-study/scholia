{
    "db_name": "PostgreSQL",
    "query": "SELECT aq.id, aq.article_id, aq.article_title,\n                  aq.author_display_name, aq.text, aq.html,\n                  COUNT(qn.id) AS \"note_count?\",\n                  aq.created_at\n           FROM article_quotations aq\n           LEFT JOIN quotation_notes qn ON qn.article_quotation_id = aq.id\n           WHERE aq.id = $1\n           GROUP BY aq.id",
