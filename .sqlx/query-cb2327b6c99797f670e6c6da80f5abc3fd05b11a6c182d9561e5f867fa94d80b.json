    "query": "SELECT at2.article_id, t.id AS topic_id, t.name AS topic_name, t.slug AS topic_slug\n           FROM article_topics at2\n           JOIN topics t ON t.id = at2.topic_id\n           WHERE at2.article_id = ANY($1)\n           ORDER BY t.name",
