    "query": "SELECT tn.slug, tn.label, tn.sort_order\n               FROM toc_nodes tn\n               JOIN books b ON b.id = tn.book_id\n               WHERE b.slug = $1 AND tn.depth = 0 AND tn.source_id IS NOT NULL\n               ORDER BY tn.sort_order",
