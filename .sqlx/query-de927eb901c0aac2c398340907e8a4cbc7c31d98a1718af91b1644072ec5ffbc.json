    "query": "SELECT a.title,\n                  u.display_name AS \"author_display_name!\",\n                  u.sort_name    AS \"author_sort_name?\",\n                  a.published_at,\n                  a.html AS \"html!\"\n           FROM articles a\n           JOIN users u ON u.id = a.user_id\n           WHERE a.id = $1 AND a.status IN ('published', 'archived')",
