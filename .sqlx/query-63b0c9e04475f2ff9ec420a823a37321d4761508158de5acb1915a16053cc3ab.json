    "query": "SELECT tn.id, tn.source_ref, tn.slug, tn.label, tn.depth, tn.sort_order, tn.source_node_id\n               FROM toc_nodes tn\n               JOIN books b ON b.id = tn.book_id\n               WHERE b.slug = $1 AND tn.sort_order > $2\n               ORDER BY tn.sort_order\n               LIMIT $3",
