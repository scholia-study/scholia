    "query": "SELECT sp.source_id,\n                  sp.role::TEXT AS \"role!\",\n                  p.id AS person_id,\n                  p.name,\n                  p.sort_name\n           FROM source_persons sp\n           JOIN persons p ON p.id = sp.person_id\n           WHERE sp.source_id = ANY($1)\n           ORDER BY sp.position",
